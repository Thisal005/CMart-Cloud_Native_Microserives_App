{
  "name": "cart-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "typeorm": "ts-node-dev ./node_modules/typeorm/cli.js -d src/config/data-source.ts",
    "migration:run": "npm run typeorm migration:run",
    "migration:revert": "npm run typeorm migration:revert"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.8",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.30",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0"
  }
}
