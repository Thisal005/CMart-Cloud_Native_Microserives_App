								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.token) {",
									"        pm.collectionVariables.set(\"jwt_token\", jsonData.data.token);",
									"        console.log(\"Saved jwt_token: \" + jsonData.data.token.substring(0, 15) + \"...\");",
									"    }",
									"    if (jsonData.data && jsonData.data.refreshToken) {",
									"        pm.collectionVariables.set(\"refresh_token\", jsonData.data.refreshToken);",
									"        console.log(\"Saved refresh_token: \" + jsonData.data.refreshToken.substring(0, 15) + \"...\");",
